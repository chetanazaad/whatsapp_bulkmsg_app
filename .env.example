FLASK_ENV=dev
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# MySQL connection (SQLAlchemy URL using mysql-connector)
DATABASE_URL=mysql+mysqlconnector://user:password@localhost:3306/whatsapp_saas

# WhatsApp Cloud API
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v21.0
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_ACCESS_TOKEN=YOUR_LONG_LIVED_ACCESS_TOKEN

SCHEDULER_ENABLED=true
SCHEDULER_JOB_INTERVAL_SECONDS=30

